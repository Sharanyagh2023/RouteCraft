# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_API_KEY: Required for Directions and Distance Matrix APIs.
GOOGLE_MAPS_API_KEY=""

# OPENWEATHER_API_KEY: Required for the Context Service (weather).
OPENWEATHER_API_KEY=""

# Namma Yatri MCP Server (Localtunnel URL)
NY_MCP_URL=""

# ONDC Configuration: Required for real-time mobility network access.
ONDC_GATEWAY_URL="https://api.ondc.org/gateway/v1"
ONDC_SUBSCRIBER_ID=""
ONDC_UKID=""
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
